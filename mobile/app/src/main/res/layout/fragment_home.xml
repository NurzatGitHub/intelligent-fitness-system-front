<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:background="?attr/colorPrimaryContainer"
                android:padding="12dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:tint="?attr/colorPrimary"
                android:layout_marginEnd="16dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:text="Welcome back"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvUserName"
                    android:text="Azamat 👋"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/ivNotifications"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="?attr/colorOnSurface" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAiWeeklyPlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvAiPlanTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Weekly Plan"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnPrimaryContainer" />

                <TextView
                    android:id="@+id/tvAiPlanSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Generating your personalized weekly plan..."
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:alpha="0.85" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDay1"
                            android:layout_width="88dp"
                            android:layout_height="110dp"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/colorOutline">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="10dp">
                                <TextView
                                    android:id="@+id/tvDay1Label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mon"
                                    android:textStyle="bold"
                                    android:textSize="12sp" />
                                <TextView
                                    android:id="@+id/tvDay1Type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="Workout"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorPrimary" />
                                <TextView
                                    android:id="@+id/tvDay1Title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:maxLines="3"
                                    android:text="Chest"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDay2"
                            android:layout_width="88dp"
                            android:layout_height="110dp"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/colorOutline">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="10dp">
                                <TextView
                                    android:id="@+id/tvDay2Label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tue"
                                    android:textStyle="bold"
                                    android:textSize="12sp" />
                                <TextView
                                    android:id="@+id/tvDay2Type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="Rest"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorPrimary" />
                                <TextView
                                    android:id="@+id/tvDay2Title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:maxLines="3"
                                    android:text="Recovery"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDay3"
                            android:layout_width="88dp"
                            android:layout_height="110dp"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/colorOutline">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="10dp">
                                <TextView
                                    android:id="@+id/tvDay3Label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Wed"
                                    android:textStyle="bold"
                                    android:textSize="12sp" />
                                <TextView
                                    android:id="@+id/tvDay3Type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="Workout"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorPrimary" />
                                <TextView
                                    android:id="@+id/tvDay3Title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:maxLines="3"
                                    android:text="Back"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDay4"
                            android:layout_width="88dp"
                            android:layout_height="110dp"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/colorOutline">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="10dp">
                                <TextView
                                    android:id="@+id/tvDay4Label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Thu"
                                    android:textStyle="bold"
                                    android:textSize="12sp" />
                                <TextView
                                    android:id="@+id/tvDay4Type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="Rest"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorPrimary" />
                                <TextView
                                    android:id="@+id/tvDay4Title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:maxLines="3"
                                    android:text="Mobility"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDay5"
                            android:layout_width="88dp"
                            android:layout_height="110dp"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/colorOutline">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="10dp">
                                <TextView
                                    android:id="@+id/tvDay5Label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Fri"
                                    android:textStyle="bold"
                                    android:textSize="12sp" />
                                <TextView
                                    android:id="@+id/tvDay5Type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="Workout"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorPrimary" />
                                <TextView
                                    android:id="@+id/tvDay5Title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:maxLines="3"
                                    android:text="Legs"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDay6"
                            android:layout_width="88dp"
                            android:layout_height="110dp"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/colorOutline">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="10dp">
                                <TextView
                                    android:id="@+id/tvDay6Label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sat"
                                    android:textStyle="bold"
                                    android:textSize="12sp" />
                                <TextView
                                    android:id="@+id/tvDay6Type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="Workout"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorPrimary" />
                                <TextView
                                    android:id="@+id/tvDay6Title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:maxLines="3"
                                    android:text="Full body"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDay7"
                            android:layout_width="88dp"
                            android:layout_height="110dp"
                            app:cardCornerRadius="16dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/colorOutline">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="10dp">
                                <TextView
                                    android:id="@+id/tvDay7Label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sun"
                                    android:textStyle="bold"
                                    android:textSize="12sp" />
                                <TextView
                                    android:id="@+id/tvDay7Type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="Rest"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorPrimary" />
                                <TextView
                                    android:id="@+id/tvDay7Title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:maxLines="3"
                                    android:text="Recovery"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tvTodayPlan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Today"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnPrimaryContainer" />

                <TextView
                    android:id="@+id/tvTodayMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Your today plan will appear here"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:alpha="0.9" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:text="@string/home_choose_category"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <com.example.fitnesscoachai.ui.home.ExpandableHeightRecyclerView
            android:id="@+id/rvCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_category_card" />

        <TextView
            android:text="Your Stats"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvTotalWorkouts"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="Workouts"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvAverageFormScore"
                        android:text="0%"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="Form Score"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</ScrollView>